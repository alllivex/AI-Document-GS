      "block_trace_id": "trace_ai_doc_1f623d32-ce4c-59b4-b195-24463c9fbaa1_AIBLOCK0",
      "block_trace_kind": "ai",
      "runs": [
        {
          "text": "根据知识库信息及不良额环比上升",
          "trace_id": null,
