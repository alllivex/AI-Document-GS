      "block_trace_kind": "ai",
      "runs": [
        {
          "text": "根据提供的知识库信息以及不良额环比上升",
          "trace_id": null,
          "trace_kind": null,
          "ai_block_id": null,
          "style": null
        },
        {
          "text": "0.12",
          "trace_id": "trace_e6fcf8b1-dd42-55e7-8124-620c531f5128",
          "trace_kind": "field",
          "ai_block_id": null,
          "style": null
        },
        {
          "text": "、同比上升",
