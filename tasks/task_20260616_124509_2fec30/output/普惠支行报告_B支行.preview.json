      "block_trace_id": "trace_ai_doc_e100756b-6244-5047-89ea-841a9969a056_AIBLOCK0",
      "block_trace_kind": "ai",
      "runs": [
        {
          "text": "根据知识库信息以及不良额环比下降0.03、同比上升",
          "trace_id": null,
          "trace_kind": null,
          "ai_block_id": null,
