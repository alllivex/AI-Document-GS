          "ai_block_id": null,
          "style": null
        },
        {
          "text": "0.12",
          "trace_id": "trace_e18b0522-5278-5571-a4d0-126fe9f855dc",
          "trace_kind": "field",
          "ai_block_id": null,
          "style": null
        },
        {
          "text": "、同比上升",
          "trace_id": null,
