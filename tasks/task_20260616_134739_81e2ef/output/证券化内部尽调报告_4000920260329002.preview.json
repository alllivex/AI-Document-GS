    {
      "type": "paragraph",
      "block_id": "paragraph_959b258322e24f5ebfbf95af2e16adbd",
      "block_trace_id": "trace_ai_doc_a0d4bf1e-859f-5844-8f90-ed955025baf8_AIBLOCK0",
      "block_trace_kind": "ai",
      "runs": [
        {
          "text": "根据企业查询数据，",
          "trace_id": null,
          "trace_kind": null,
          "ai_block_id": null,
          "style": null
        },
        {
          "text": "广州慧联科技有限公司",
          "trace_id": "trace_368f67aa-c905-56d4-95a7-8c65a151bd0f",
          "trace_kind": "field",
          "ai_block_id": null,
          "style": null
        },
        {
          "text": "成立于2020年3月15日，注册资本800万元，注册地址与经营地址均为广州市天河区软件园贝里路18号。法定代表人陈志刚，实际控制人为广州慧联投资集团（持股70%）及陈志刚（持股30%）。公司主营人工智能算法开发、大数据分析服务、云计算平台运营及智能硬件租赁，所属软件和信息技术服务业，企业规模为小型，即期信用等级需补充为B级。\n\n企业经营实情显示，公司因2025年AI项目投资失败导致研发投入超预算，叠加宏观经济下行及客户需求减少，应收账款逾期率超50%，现金流断裂。核心技术人员流失致使项目停滞，公司目前已停止运营，并涉及多起法律诉讼。综合判断，该公司经营状况严重恶化，偿债能力显著下降，信用风险极高。建议后续加强贷后监控，审慎处理相关授信业务。",
          "trace_id": null,
          "trace_kind": null,
          "ai_block_id": null,
          "style": null
        }
      ],
      "style": null
    }
  ],
