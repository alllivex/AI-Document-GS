      "runs": [
        {
          "text": "抵押担保情况判断：担保方式为最高额抵质押的最高额不能够覆盖全部债权本息 。",
          "trace_id": "trace_condition_doc_a0d4bf1e-859f-5844-8f90-ed955025baf8_condition_0",
