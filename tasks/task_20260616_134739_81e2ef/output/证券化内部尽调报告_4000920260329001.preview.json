      "block_trace_kind": "condition",
      "runs": [
        {
          "text": "抵押担保情况判断：担保方式为最高额抵质押的最高额能够覆盖全部债权本息。",
          "trace_id": "trace_condition_doc_bc4fc49a-174e-51c5-9a30-c7834ee1d307_condition_0",
          "trace_kind": "condition",
